# PostgreSQL (required)
DATABASE_URL=postgresql://user:password@localhost:5432/vadi_hisab
# or
# PG_URI=postgresql://user:password@localhost:5432/vadi_hisab
#
# Supabase: copy "URI" from Project Settings → Database (host looks like db.<project-ref>.supabase.co).
# If you see ENOTFOUND for db.*.supabase.co on Windows: ipconfig /flushdns, try DNS 8.8.8.8, or disable VPN.
# Pooler (port 6543) uses host *.pooler.supabase.com — also supported; SSL is enabled automatically for Supabase hosts.

# JWT
JWT_SECRET=your-secret-key-min-32-chars

# 2Factor.in for OTP
TWO_FACTOR_API_KEY=your-api-key
# OTP delivery: sms (default) or voice (phone call)
# OTP_CHANNEL=sms
# OTP_CHANNEL=voice

# Optional
NODE_ENV=development

# APMC / Mandi crop prices — synced daily into PostgreSQL (app reads from DB; fast, no data.gov.in per request)
# Get API key: https://data.gov.in → Register → My Account
# DATA_GOV_IN_API_KEY=your-40-char-api-key
# DATA_GOV_IN_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
# Districts to sync (comma-separated English names, must match Agmarknet). Default ALL = every district in data/gujarat-locations.json
# APMC_SYNC_DISTRICTS=ALL
# APMC_SYNC_DISTRICTS=Rajkot,Jamnagar
# Pause ms between districts when calling data.gov.in (rate limits)
# APMC_INTER_DISTRICT_DELAY_MS=400
# HTTP timeout per request (ms) — raise if you see timeout errors
# APMC_TIMEOUT_MS=120000
# Retries per page when data.gov.in is slow
# APMC_FETCH_RETRIES=4
# Max rows per POST /api/apmc/manual
# APMC_MANUAL_IMPORT_MAX=500

# Mandi table (api.data.gov.in/resource/… — same DATA_GOV_IN_API_KEY)
# MANDI_TIMEOUT_MS=120000
# MANDI_PAGE_LIMIT=1000
# MANDI_CRON=0 9 * * *
# MANDI_CRON_TZ=Asia/Kolkata
# Daily sync time (5-field cron), India time
# APMC_CRON=0 6 * * *
# APMC_CRON_TZ=Asia/Kolkata
